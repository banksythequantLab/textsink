# Copy to .env and fill in. Required for real runs (omit for --mock).
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# === Gemma 4 (Best Use of Gemma 4 bonus) — RECOMMENDED ====================
# Gemma 4 is deploy-only on Fireworks. Create an on-demand deployment (README),
# then reference it as base#deployment. Gemma 4 does BOTH vision + captions.
VISION_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it#accounts/<acct>/deployments/<dep>
CAPTION_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it#accounts/<acct>/deployments/<dep>
REASONING_EFFORT=none            # Gemma 4 needs "none" to suppress its thinking

# === Serverless fallback (no deployment needed) ==========================
# VISION_MODEL=accounts/fireworks/models/qwen3p7-plus
# CAPTION_MODEL=accounts/fireworks/models/gpt-oss-120b
# REASONING_EFFORT=low

JUDGE_MODEL=accounts/fireworks/models/gpt-oss-120b
TRANSCRIBE_BACKEND=none
WHISPER_MODEL=base
FPS_SAMPLE=0.2
MIN_FRAMES=8
MAX_FRAMES=16
FRAME_WIDTH=512
TEMPERATURE=0.4
MAX_TOKENS=320
SCENE_MAX_TOKENS=1200
